     1	// Deterministic checks that LLMs cannot reliably perform themselves.
     2	// Everything semantic (boundary, source grounding, etc.) is the Codex
     3	// validator's job; this module only does:
     4	//   - "did Claude actually write all expected files?"
     5	//   - "is each YAML / JSON parseable?"
     6	//   - "does the Codex validation report match the Zod schema?"
     7	// Nothing here makes pass/fail judgments about boundary rules.
     8	
     9	import { promises as fs } from "node:fs";
    10	import path from "node:path";
    11	import YAML from "yaml";
    12	import {
    13	  CodexValidationReportSchema,
    14	  ExpectedArtifactFiles,
    15	} from "../schemas/index.js";
    16	
    17	export interface ArtifactCheckIssue {
    18	  path: string;
    19	  reason: string;
    20	}
    21	
    22	export interface ArtifactCheckResult {
    23	  missing: ArtifactCheckIssue[];
    24	  unparseable: ArtifactCheckIssue[];
    25	  ok: boolean;
    26	}
    27	
    28	export async function checkArtifacts(featureDir: string): Promise<ArtifactCheckResult> {
    29	  const missing: ArtifactCheckIssue[] = [];
    30	  const unparseable: ArtifactCheckIssue[] = [];
    31	  for (const file of ExpectedArtifactFiles) {
    32	    const fullPath = path.join(featureDir, file);
    33	    try {
    34	      const text = await fs.readFile(fullPath, "utf8");
    35	      if (file.endsWith(".yaml")) {
    36	        try {
    37	          YAML.parse(text);
    38	        } catch (e) {
    39	          unparseable.push({ path: fullPath, reason: (e as Error).message });
    40	        }
    41	      }
    42	    } catch {
    43	      missing.push({ path: fullPath, reason: "file does not exist" });
    44	    }
    45	  }
    46	  return { missing, unparseable, ok: missing.length === 0 && unparseable.length === 0 };
    47	}
    48	
    49	export interface ReportCheckResult {
    50	  ok: boolean;
    51	  issues: string[];
    52	}
    53	
    54	export async function checkCodexReport(jsonPath: string): Promise<ReportCheckResult> {
    55	  let raw: string;
    56	  try {
    57	    raw = await fs.readFile(jsonPath, "utf8");
    58	  } catch {
    59	    return { ok: false, issues: [`report not found at ${jsonPath}`] };
    60	  }
    61	  let json: unknown;
    62	  try {
    63	    json = JSON.parse(raw);
    64	  } catch (e) {
    65	    return { ok: false, issues: [`report is not valid JSON: ${(e as Error).message}`] };
    66	  }
    67	  const parsed = CodexValidationReportSchema.safeParse(json);
    68	  if (!parsed.success) {
    69	    return {
    70	      ok: false,
    71	      issues: parsed.error.issues.map((i) => `${i.path.join(".")}: ${i.message}`),
    72	    };
    73	  }
    74	  return { ok: true, issues: [] };
    75	}

