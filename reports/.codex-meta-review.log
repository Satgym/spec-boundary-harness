     1	#!/usr/bin/env node
     2	// Render reports/codex-validation-report.json as Markdown.
     3	// Pure JS, no deps, runs after codex-validate.sh writes the canonical JSON.
     4	import { readFileSync } from "node:fs";
     5	
     6	const file = process.argv[2];
     7	if (!file) {
     8	  console.error("usage: render-validation-md.mjs <report.json>");
     9	  process.exit(2);
    10	}
    11	const data = JSON.parse(readFileSync(file, "utf8"));
    12	
    13	const lines = [
    14	  "# Codex Validation Report",
    15	  "",
    16	  `Generated: ${data.generated_at}`,
    17	  `Feature: ${data.feature_id ?? "(unspecified)"}`,
    18	  "",
    19	  "## Input summary",
    20	  "",
    21	  data.input_summary ?? "(no summary)",
    22	  "",
    23	  "## Findings",
    24	  "",
    25	];
    26	
    27	const findings = Array.isArray(data.findings) ? data.findings : [];
    28	if (findings.length === 0) {
    29	  lines.push("- (none)");
    30	} else {
    31	  const counts = { low: 0, medium: 0, high: 0, critical: 0 };
    32	  for (const f of findings) {
    33	    counts[f.severity] = (counts[f.severity] ?? 0) + 1;
    34	  }
    35	  lines.push(
    36	    `Counts: critical=${counts.critical}, high=${counts.high}, medium=${counts.medium}, low=${counts.low}`
    37	  );
    38	  lines.push("");
    39	  for (const f of findings) {
    40	    lines.push(
    41	      `### ${f.id} — [${f.severity}] ${f.validator}${f.artifact ? ` (${f.artifact})` : ""}`
    42	    );
    43	    lines.push("");
    44	    lines.push(`- Message: ${f.message}`);
    45	    if (f.evidence) lines.push(`- Evidence: ${f.evidence}`);
    46	    if (f.suggested_fix) lines.push(`- Suggested fix: ${f.suggested_fix}`);
    47	    lines.push("");
    48	  }
    49	}
    50	
    51	if (data.notes) {
    52	  lines.push("## Notes");
    53	  lines.push("");
    54	  lines.push(data.notes);
    55	}
    56	
    57	process.stdout.write(lines.join("\n") + "\n");

