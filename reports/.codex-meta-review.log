    14	
    15	const SEARCH_ROOTS = ["inputs", "examples"];
    16	
    17	function looksLikeInput(entryPath: string): boolean {
    18	  // A directory is treated as an input bundle when at least one of these
    19	  // subdirectories or files is present.
    20	  return ["prd", "plaud", "endpoints", "design", "profile.yaml"].some((sub) => {
    21	    try {
    22	      statSync(path.join(entryPath, sub));
    23	      return true;
    24	    } catch {
    25	      return false;
    26	    }
    27	  });
    28	}
    29	
    30	// Convert a folder name into a feature id.
    31	//   "auth.login"       -> "auth.login"   (kept as-is)
    32	//   "auth-login"       -> "auth.login"   (dashes -> dot)
    33	//   "auth_login"       -> "auth.login"   (underscores -> dot)
    34	//   "auth/login"       -> "auth.login"
    35	//   anything else      -> kept as-is, with whitespace collapsed
    36	export function folderNameToFeatureId(name: string): string {
    37	  const normalized = name.trim().replace(/\s+/g, "-");
    38	  if (/^[a-z0-9]+(\.[a-z0-9]+)+$/i.test(normalized)) return normalized;
    39	  return normalized.replace(/[\/_-]/g, ".");
    40	}
    41	
    42	export async function detectInputs(rootDir: string): Promise<DetectResult> {
    43	  const out: DetectedInput[] = [];
    44	  const searched: string[] = [];
    45	  for (const subdir of SEARCH_ROOTS) {
    46	    const full = path.join(rootDir, subdir);
    47	    searched.push(full);
    48	    if (!(await exists(full))) continue;
    49	    const entries = await fs.readdir(full, { withFileTypes: true });
    50	    for (const e of entries) {
    51	      if (!e.isDirectory()) continue;
    52	      const entryPath = path.join(full, e.name);
    53	      if (!looksLikeInput(entryPath)) continue;
    54	      out.push({
    55	        inputDir: entryPath,
    56	        featureId: folderNameToFeatureId(e.name),
    57	      });
    58	    }
    59	  }
    60	  return { candidates: out, searchedRoots: searched };
    61	}

