   125	      "validator": "source-coverage" | "boundary-violation" | "endpoint-coverage" | "screen-state-coverage" | "openapi-patch" | "conflict-blocking" | "prompt-injection" | "packet-scope" | "other",
   126	      "severity": "low" | "medium" | "high" | "critical",
   127	      "feature_id": "<feature id>",
   128	      "artifact": "<relative path of the artifact most relevant to this finding, or null>",
   129	      "message": "<one or two sentences explaining the problem>",
   130	      "evidence": "<quote or specific line/section reference; or null if unavailable>",
   131	      "suggested_fix": "<concrete suggestion; or null>"
   132	    }
   133	  ],
   134	  "notes": "<global notes, or null — but the key must be present>"
   135	}
   136	```
   137	
