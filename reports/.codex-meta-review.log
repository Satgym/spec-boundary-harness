     1	#!/usr/bin/env bash
     2	# Codex validator runner.
     3	#
     4	# Usage:
     5	#   scripts/codex-validate.sh <inputDir> <featureId>
     6	#
     7	# Behavior:
     8	#   - Read-only sandbox; never modifies repository files.
     9	#   - Uses prompts/codex-validator.md as the system prompt.
    10	#   - Uses schemas/codex-validation-report.schema.json to enforce JSON shape.
    11	#   - Writes reports/codex-validation-report.json and a human-readable .md mirror.
    12	#   - Skips gracefully if codex is unavailable or required flags are missing.
    13	
    14	set -u
    15	
    16	ROOT_DIR="${ROOT_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
    17	INPUT_DIR="${1:?usage: $0 <inputDir> <featureId>}"
    18	FEATURE_ID="${2:?usage: $0 <inputDir> <featureId>}"
    19	
    20	PROMPT_FILE="$ROOT_DIR/prompts/codex-validator.md"
    21	SCHEMA_FILE="$ROOT_DIR/schemas/codex-validation-report.schema.json"
    22	OUTPUT_JSON="$ROOT_DIR/reports/codex-validation-report.json"
    23	OUTPUT_MD="$ROOT_DIR/reports/codex-validation-report.md"
    24	LOG_FILE="$ROOT_DIR/reports/.codex-validate.log"
    25	mkdir -p "$(dirname "$OUTPUT_JSON")"
    26	
    27	write_skip() {
    28	  local reason="$1"
    29	  cat > "$OUTPUT_MD" <<EOF
    30	# Codex Validation Report
    31	
    32	Status: SKIPPED
    33	
    34	Reason: $reason
    35	
    36	The harness intentionally avoids invoking Codex unless it can confirm a safe read-only sandbox.
    37	EOF
    38	  cat > "$OUTPUT_JSON" <<EOF
    39	{
    40	  "generated_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
    41	  "feature_id": "$FEATURE_ID",
    42	  "input_summary": "Codex was not invoked: $reason",
    43	  "findings": [],
    44	  "notes": "skipped"
    45	}
    46	EOF
    47	}
    48	
    49	if ! command -v codex >/dev/null 2>&1; then
    50	  write_skip "codex CLI not found on PATH"
    51	  exit 0
    52	fi
    53	if [ ! -f "$PROMPT_FILE" ]; then
    54	  write_skip "Missing prompt: $PROMPT_FILE"
    55	  exit 0
    56	fi
    57	if [ ! -f "$SCHEMA_FILE" ]; then
    58	  write_skip "Missing schema: $SCHEMA_FILE"
    59	  exit 0
    60	fi
    61	if [ ! -d "$ROOT_DIR/specs/$FEATURE_ID" ]; then
    62	  write_skip "No specs/$FEATURE_ID directory; nothing to validate"
